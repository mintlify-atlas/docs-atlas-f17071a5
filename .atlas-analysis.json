  "keyFeatures": [
    "Deploy and manage multiple Scrapy projects",
    "HTTP JSON API for remote control",
    "Job scheduling with priority queues",
    "Concurrent spider execution",
    "Web UI for monitoring",
    "Version management for projects",
    "Authentication support",
    "Extensible plugin architecture"
  ],
  "publicApiSurface": [
    "schedule.json - Schedule a spider to run",
    "cancel.json - Cancel a running or pending job",
    "status.json - Get job status",
    "daemonstatus.json - Get daemon load status",
    "listjobs.json - List pending, running, and finished jobs",
    "listprojects.json - List all projects",
    "listversions.json - List project versions",
    "listspiders.json - List spiders in a project",
    "addversion.json - Deploy a new project version",
    "delproject.json - Delete a project",
    "delversion.json - Delete a project version",
    "scrapyd - CLI command to start the daemon",
    "IEggStorage - Interface for project storage",
    "IPoller - Interface for job polling",
    "ISpiderQueue - Interface for job queuing",
    "ISpiderScheduler - Interface for job scheduling",
    "IEnvironment - Interface for process environment",
    "IJobStorage - Interface for finished job storage"
  ]
}
